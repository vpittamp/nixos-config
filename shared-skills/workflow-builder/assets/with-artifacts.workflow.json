{
  "name": "Minimal Agent with Artifact",
  "engineType": "dapr",
  "spec": {
    "document": {
      "dsl": "1.0.0",
      "namespace": "workflow-builder",
      "name": "minimal-agent-with-artifact",
      "version": "1.0.0",
      "title": "Minimal Agent + workflow_artifact",
      "summary": "Single durable/run step that persists its markdown response as a workflow_artifact (slot=primary). Renders front-and-centre on the run-detail Overview tab + appears on the new Outputs tab. Replace agentRef.id/slug with a real agent."
    },
    "input": {
      "schema": {
        "format": "json",
        "document": {
          "type": "object",
          "properties": {
            "topic": {
              "type": "string",
              "title": "Topic",
              "default": "Why Gateway API replaces Ingress in 2026"
            }
          },
          "required": ["topic"]
        }
      }
    },
    "do": [
      {
        "synthesize": {
          "call": "durable/run",
          "with": {
            "agentRef": {
              "id": "REPLACE_WITH_REAL_AGENT_ID",
              "slug": "REPLACE_WITH_REAL_AGENT_SLUG"
            },
            "prompt": "${ \"Write a 200-word explainer about: \" + .trigger.topic + \". End with TASK COMPLETE.\" }",
            "mode": "execute_direct",
            "maxTurns": 4,
            "timeoutMinutes": 5,
            "workspaceRef": "local",
            "stopCondition": "Stop after the response ends with TASK COMPLETE."
          },
          "artifacts": [
            {
              "kind": "markdown",
              "slot": "primary",
              "title": "Explainer",
              "description": "${ .trigger.topic }",
              "from": "${ .data.content }",
              "contentType": "text/markdown",
              "metadata": "${ { topic: .trigger.topic, turn: .data.turn, model: .data.modelSpec } }"
            }
          ]
        }
      }
    ],
    "output": {
      "as": {
        "answer": "${ .synthesize.data.content }"
      }
    }
  },
  "nodes": [
    {
      "id": "__start__",
      "type": "start",
      "position": { "x": 250, "y": 50 },
      "data": {
        "label": "Start",
        "type": "start",
        "status": "idle",
        "enabled": true,
        "taskConfig": {
          "input": {
            "format": "json",
            "schema": {
              "format": "json",
              "document": {
                "type": "object",
                "properties": {
                  "topic": { "type": "string", "title": "Topic", "default": "Why Gateway API replaces Ingress in 2026" }
                },
                "required": ["topic"]
              }
            }
          }
        }
      }
    },
    {
      "id": "synthesize",
      "type": "agent",
      "position": { "x": 250, "y": 200 },
      "data": {
        "label": "Synthesize",
        "type": "agent",
        "status": "idle",
        "enabled": true,
        "agent": {
          "id": "REPLACE_WITH_REAL_AGENT_ID",
          "slug": "REPLACE_WITH_REAL_AGENT_SLUG",
          "runtime": "dapr-agent-py"
        },
        "taskConfig": {
          "call": "durable/run",
          "with": {
            "agentRef": {
              "id": "REPLACE_WITH_REAL_AGENT_ID",
              "slug": "REPLACE_WITH_REAL_AGENT_SLUG"
            },
            "prompt": "${ \"Write a 200-word explainer about: \" + .trigger.topic + \". End with TASK COMPLETE.\" }",
            "mode": "execute_direct",
            "maxTurns": 4,
            "timeoutMinutes": 5,
            "workspaceRef": "local",
            "stopCondition": "Stop after the response ends with TASK COMPLETE."
          },
          "artifacts": [
            {
              "kind": "markdown",
              "slot": "primary",
              "title": "Explainer",
              "description": "${ .trigger.topic }",
              "from": "${ .data.content }",
              "contentType": "text/markdown",
              "metadata": "${ { topic: .trigger.topic, turn: .data.turn, model: .data.modelSpec } }"
            }
          ]
        }
      }
    },
    {
      "id": "__end__",
      "type": "end",
      "position": { "x": 250, "y": 350 },
      "data": { "label": "End", "type": "end", "status": "idle", "enabled": true }
    }
  ],
  "edges": [
    { "id": "__start__->synthesize", "source": "__start__", "target": "synthesize" },
    { "id": "synthesize->__end__", "source": "synthesize", "target": "__end__" }
  ]
}
